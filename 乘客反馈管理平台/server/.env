# Database Configuration - Using Docker MySQL on port 3307
DATABASE_URL=mysql+aiomysql://root:root_password@127.0.0.1:3307/robotaxi

# AI API Configuration - Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# AI API Configuration - MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# AI Configuration
AI_MODEL=moonshot-v1-8k
AI_TIMEOUT=60

# Server Configuration
DEBUG=true
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
APP_NAME=Robotaxi Feedback Platform
API_PREFIX=/api
